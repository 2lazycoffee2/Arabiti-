  {
    "id": "vl_alif",
    "name": "Alif Madd",
    "letter": "آ / ا",
    "isolated": "ā",
    "initial": "-",
    "medial": "-",
    "final": "-",
    "pronunciation": "â long (ex: بَاب = bāb)",
    "type": "voyelle longue",
    "category": "Voyelles Longues",
    "description": "L'Alif prolonge le son 'A' de la Fatha. Écrit ا après une Fatha, ou آ au début d'un mot. C'est deux fois plus long qu'un A bref.",
    "example": "بَابٌ (bāb = porte) — كِتَابٌ (kitāb = livre)"
  },
  {
    "id": "vl_waaw",
    "name": "Wāw Al-Madd",
    "letter": "و",
    "isolated": "ū",
    "initial": "-",
    "medial": "-",
    "final": "-",
    "pronunciation": "ū long (ex: نُور = nūr)",
    "type": "voyelle longue",
    "category": "Voyelles Longues",
    "description": "Le Waaw allonge le son 'OU' de la Damma. La lettre و après une Damma produit un OU long — différent du W consonantique.",
    "example": "نُورٌ (nūr = lumière) — يَقُولُ (yaqūlu = il dit)"
  },
  {
